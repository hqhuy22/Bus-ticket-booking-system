{
  "name": "bus-ticket-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "ts-node-dev --respawn --transpile-only src/db/migrate.ts",
    "seed": "ts-node-dev --respawn --transpile-only src/db/seedAdmin.ts",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node ./scripts/copyPublic.js",
    "start": "node dist/server.js",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "lint": "cross-env TSESTREE_DISABLE_VERSION_CHECK=true eslint \"src/**/*.{ts,js}\" --ext .ts --fix",
    "test": "jest --runInBand",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && husky install || echo \"Skipping husky install: not a git repo\""
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
  "joi": "^17.9.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.4",
  "qrcode": "^1.5.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.5.6",
    "@types/nodemailer": "^6.4.7",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.6"
  }
}
