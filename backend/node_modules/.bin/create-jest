#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/Bus-ticket-booking-system/backend/node_modules/create-jest/bin/node_modules:/mnt/d/Bus-ticket-booking-system/backend/node_modules/create-jest/node_modules:/mnt/d/Bus-ticket-booking-system/backend/node_modules:/mnt/d/Bus-ticket-booking-system/node_modules:/mnt/d/node_modules:/mnt/d/Bus-ticket-booking-system/backend/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/Bus-ticket-booking-system/backend/node_modules/create-jest/bin/node_modules:/mnt/d/Bus-ticket-booking-system/backend/node_modules/create-jest/node_modules:/mnt/d/Bus-ticket-booking-system/backend/node_modules:/mnt/d/Bus-ticket-booking-system/node_modules:/mnt/d/node_modules:/mnt/d/Bus-ticket-booking-system/backend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../create-jest/bin/create-jest.js" "$@"
else
  exec node  "$basedir/../create-jest/bin/create-jest.js" "$@"
fi
